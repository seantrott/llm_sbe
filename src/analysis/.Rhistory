labs(x = "Accuracy (Mental States)",
y = "Accuracy (Pragmatic Inference)",
color = "", shape = "") +
theme_minimal() +
scale_color_manual(values = viridisLite::viridis(8, option = "mako",
begin = 0.8, end = 0.15)) +
theme(text = element_text(size = 15), legend.position = "bottom")
df_all_tests %>%
ggplot(aes(x = num_params,
y = perplexity,
shape = base_instruct,
color = model_family)) +
geom_point(size = 6, alpha = .5) +
scale_x_log10() +
scale_y_log10() +
geom_smooth(method = "lm", color = "blue", aes(color = NULL, group = 1)) +
theme_minimal() +
scale_color_manual(values = viridisLite::viridis(8, option = "mako",
begin = 0.8, end = 0.15)) +
theme(text = element_text(size = 15), legend.position = "bottom") +
labs(x = "Parameters (Log10)", y = "Perplexity (Log10)", color = "", shape = "")
df_renamed <- df_renamed %>%
mutate(log_perplexity = log10(perplexity))
# Correlation of each task with log(perplexity)
ppl_cors <- sapply(tom_tasks, function(t) {
cor(df_renamed[[t]], df_renamed$log_perplexity,
use = "pairwise.complete.obs", method = "spearman")
})
# For each task pair, compare pairwise r to what perplexity alone would predict
pair_comparison_ppl <- expand.grid(task1 = tom_tasks, task2 = tom_tasks,
stringsAsFactors = FALSE) %>%
filter(task1 < task2) %>%
rowwise() %>%
mutate(
pairwise_r = cor(df_renamed[[task1]], df_renamed[[task2]],
use = "pairwise.complete.obs", method = "spearman"),
task1_ppl_r = ppl_cors[task1],
task2_ppl_r = ppl_cors[task2],
avg_ppl_r = (abs(task1_ppl_r) + abs(task2_ppl_r)) / 2,
excess_r = pairwise_r - avg_ppl_r
)
print(pair_comparison_ppl %>%
select(task1, task2, pairwise_r, avg_ppl_r, excess_r) %>%
arrange(desc(excess_r)))
pair_comparison_ppl %>%
ggplot(aes(x = excess_r)) +
geom_histogram(bins = 10) +
geom_density() +
geom_vline(xintercept = 0, linetype = "dotted") +
labs(x = "Correlation Difference (vs. Perplexity)") +
theme_minimal()
# Build a matrix from the excess_r values
excess_mat_ppl <- matrix(0, nrow = length(tom_tasks), ncol = length(tom_tasks),
dimnames = list(tom_tasks, tom_tasks))
for (i in 1:nrow(pair_comparison_ppl)) {
t1 <- pair_comparison_ppl$task1[i]
t2 <- pair_comparison_ppl$task2[i]
excess_mat_ppl[t1, t2] <- pair_comparison_ppl$excess_r[i]
excess_mat_ppl[t2, t1] <- pair_comparison_ppl$excess_r[i]
}
diag(excess_mat_ppl) <- NA
ggcorrplot(excess_mat_ppl, method = "square",
title = "Excess correlation beyond perplexity (Spearman)",
colors = c("blue", "white", "red"),
tl.cex = 12)
### Resid correlation (partialing out perplexity)
resid_cols_ppl <- sapply(tom_tasks, function(t) {
resid(lm(df_renamed[[t]] ~ df_renamed$log_perplexity, na.action = na.exclude))
})
resid_cor_ppl <- cor(resid_cols_ppl, use = "pairwise.complete.obs", method = "spearman")
ggcorrplot(resid_cor_ppl, hc.order = TRUE, method = "square",
title = "Residual correlation (perplexity partialed out)")
## Size-mediated correlation analysis
df_renamed <- df_renamed %>%
mutate(log_params = log10(num_params))
# Correlation of each task with log(params)
size_cors <- sapply(tom_tasks, function(t) {
cor(df_renamed[[t]], df_renamed$log_params,
use = "pairwise.complete.obs", method = "spearman")
})
# For each task pair, compare pairwise r to what size alone would predict
pair_comparison <- expand.grid(task1 = tom_tasks, task2 = tom_tasks,
stringsAsFactors = FALSE) %>%
filter(task1 < task2) %>%
rowwise() %>%
mutate(
pairwise_r = cor(df_renamed[[task1]], df_renamed[[task2]],
use = "pairwise.complete.obs", method = "spearman"),
task1_size_r = size_cors[task1],
task2_size_r = size_cors[task2],
avg_size_r = (abs(task1_size_r) + abs(task2_size_r)) / 2,
excess_r = pairwise_r - avg_size_r
)
print(pair_comparison %>%
select(task1, task2, pairwise_r, avg_size_r, excess_r) %>%
arrange(desc(excess_r)))
pair_comparison %>%
ggplot(aes(x = excess_r)) +
geom_histogram(bins = 10) +
geom_density() +
geom_vline(xintercept = 0, linetype = "dotted") +
labs(x = "Correlation Difference (vs. #Params)") +
theme_minimal()
# Build a matrix from the excess_r values
excess_mat <- matrix(0, nrow = length(tom_tasks), ncol = length(tom_tasks),
dimnames = list(tom_tasks, tom_tasks))
for (i in 1:nrow(pair_comparison)) {
t1 <- pair_comparison$task1[i]
t2 <- pair_comparison$task2[i]
excess_mat[t1, t2] <- pair_comparison$excess_r[i]
excess_mat[t2, t1] <- pair_comparison$excess_r[i]
}
diag(excess_mat) <- NA  # or 0, depending on preference
ggcorrplot(excess_mat, method = "square",
title = "Excess correlation beyond size (Spearman)",
colors = c("blue", "white", "red"),
tl.cex = 12)
### Resid correlation
resid_cols <- sapply(tom_tasks, function(t) {
resid(lm(df_renamed[[t]] ~ df_renamed$log_params, na.action = na.exclude))
})
resid_cor = cor(resid_cols, use = "pairwise.complete.obs", method = "spearman")
ggcorrplot(resid_cor, hc.order = TRUE, method = "square",
title = "Residual correlation")
ppl_cors
size_cors
